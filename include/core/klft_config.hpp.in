#pragma once

#include <cstddef>

namespace klft {

inline constexpr std::size_t compiled_rank = @KLFT_NDIM@;
inline constexpr std::size_t compiled_nc = @KLFT_NC@;

inline constexpr const char *compiled_group_name() {
  if constexpr (compiled_nc == 1) {
    return "U(1)";
  } else if constexpr (compiled_nc == 2) {
    return "SU(2)";
  } else {
    return "SU(3)";
  }
}

} // namespace klft
