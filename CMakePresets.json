{
    "version": 2,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21
    },
    "configurePresets": [
        {
            "name": "relwithdebinfo",
            "displayName": "Release with Debug Info",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/../../build/klft-rel",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "Kokkos_ENABLE_OPENMP": "ON",
                "Kokkos_ARCH_ZEN3": "ON",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/../../build/klft-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "Kokkos_ENABLE_OPENMP": "ON",
                "Kokkos_ARCH_ZEN3": "ON",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "p100_4D_su2",
            "displayName": "Production P100 4D SU(2)",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/../../build/klft-p100-4D-su2",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "KLFT_NDIM": "4",
                "KLFT_NC": "2",
                "Kokkos_ENABLE_CUDA": "ON",
                "Kokkos_ENABLE_OPENMP": "ON",
                "Kokkos_ARCH_PASCAL60": "ON",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "a100_4D_su2",
            "displayName": "Production A100 4D SU(2)",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/../../build/klft-a100-4D-su2",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "KLFT_NDIM": "4",
                "KLFT_NC": "2",
                "Kokkos_ENABLE_CUDA": "ON",
                "Kokkos_ENABLE_OPENMP": "ON",
                "Kokkos_ARCH_AMPERE80": "ON",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "relwithdebinfo",
            "configurePreset": "relwithdebinfo"
        },
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "p100_4D_su2",
            "configurePreset": "p100_4D_su2"
        },
        {
            "name": "a100_4D_su2",
            "configurePreset": "a100_4D_su2"
        }
    ]
}
